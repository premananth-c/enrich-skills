# Production / Docker Compose — copy to .env and fill in real values.
# Used by: docker compose -f docker-compose.prod.yml

# Database (native PostgreSQL on host; user created with createuser)
DB_PASSWORD=changeme

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET=changeme

# Cloudflare R2 (from R2 → Manage R2 API Tokens)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=rankership
# Optional: public CDN URL for R2; leave empty to use presigned URLs
R2_PUBLIC_URL=

# Resend (email)
RESEND_API_KEY=

# Optional: AI analysis (Phase 2+)
GEMINI_API_KEY=

# Frontend URLs (for CORS, invite links)
INVITE_BASE_URL=https://student.rankership.com
STUDENT_WEB_URL=https://student.rankership.com
ADMIN_WEB_URL=https://admin.rankership.com

# Allowed domains for video streaming and CORS (comma-separated hostnames)
ALLOWED_STREAMING_DOMAINS=rankership.com,www.rankership.com,student.rankership.com,admin.rankership.com,localhost

# Optional: Sentry error tracking
SENTRY_DSN=
