generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  planId         String?
  domain         String?  @unique
  status         String   @default("active") // active, suspended, trial, cancelled
  brandingConfig Json     @default("{}")
  featureFlags   Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users             User[]
  tests             Test[]
  courses           Course[]
  questions         Question[]
  invites           Invite[]
  batches           Batch[]
  courseAssignments  CourseAssignment[]
  notifications     Notification[]
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String?
  passwordHash String
  name         String
  phoneNumber  String?
  address      String?
  role         String   @default("student") // student, admin, super_admin, or custom roleKey
  cohortIds    String[] @default([])
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attempts             Attempt[]
  invitesSent          Invite[]             @relation("InvitedBy")
  batchMembers         BatchMember[]
  courseAssignments     CourseAssignment[]
  schedulerNotes       SchedulerNote[]
  batchVideos          BatchVideo[]
  notifications        Notification[]
  activitySubmissions  ActivitySubmission[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model RoleDefinition {
  id          String   @id @default(uuid())
  tenantId    String
  roleKey     String
  displayName String
  permissions Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, roleKey])
  @@index([tenantId])
}

model Test {
  id         String   @id @default(uuid())
  tenantId   String
  title      String
  type       String   // coding, mcq
  status     String   @default("draft") // draft, published, archived
  difficulty String?
  config     Json
  schedule   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant               Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  testQuestions        TestQuestion[]
  attempts             Attempt[]
  assignmentTests      AssignmentTest[]
  variants             TestVariant[]
  allocations          TestAllocation[]
  invites              Invite[]
  courseEvaluations     CourseEvaluation[]
  batchTestAssignments BatchTestAssignment[]
}

model Question {
  id        String   @id @default(uuid())
  tenantId  String
  type      String   // coding, mcq
  content   Json
  difficulty String  // easy, medium, hard
  tags      String[] @default([])
  isArchived Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  testCases    TestCase[]
  testQuestions TestQuestion[]
  submissions  Submission[]
}

model TestCase {
  id            String   @id @default(uuid())
  questionId    String
  input         String
  expectedOutput String
  isPublic      Boolean  @default(false)
  weight        Int      @default(1)
  /// exact | json-orderless — see @enrich-skills/shared outputsMatch
  outputMatchMode String  @default("exact")
  createdAt     DateTime @default(now())

  question        Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  testCaseResults TestCaseResult[]

  @@index([questionId])
}

model TestQuestion {
  id         String  @id @default(uuid())
  testId     String
  questionId String
  order      Int     @default(0)
  variantId  String?

  test     Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
  question Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  variant  TestVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([testId, questionId])
  @@index([testId])
  @@index([variantId])
}

model TestVariant {
  id         String   @id @default(uuid())
  testId     String
  name       String
  difficulty String
  createdAt  DateTime @default(now())

  test          Test             @relation(fields: [testId], references: [id], onDelete: Cascade)
  testQuestions TestQuestion[]
  allocations   TestAllocation[]
  attempts      Attempt[]
  invites       Invite[]

  @@index([testId])
}

model TestAllocation {
  id         String   @id @default(uuid())
  userId     String
  testId     String
  variantId  String?
  assignedBy String?
  assignedAt DateTime @default(now())

  test    Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
  variant TestVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([userId, testId])
  @@index([testId])
}

model Invite {
  id        String    @id @default(uuid())
  tenantId  String
  email     String
  token     String    @unique
  expiresAt DateTime
  invitedBy String
  testId    String?
  variantId String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inviter User         @relation("InvitedBy", fields: [invitedBy], references: [id], onDelete: Cascade)
  test    Test?        @relation(fields: [testId], references: [id], onDelete: SetNull)
  variant TestVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([tenantId, email])
}

model Attempt {
  id          String    @id @default(uuid())
  userId      String
  testId      String
  variantId   String?
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  score       Float?
  maxScore    Float?
  status      String    @default("in_progress") // in_progress, submitted, graded

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  test        Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
  variant     TestVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  submissions Submission[]
}

model Submission {
  id              String   @id @default(uuid())
  attemptId       String
  questionId      String
  code            String?
  language        String?
  selectedOptionId String?
  status          String   @default("pending") // pending, running, passed, failed, error
  score           Float?
  aiRatings       Json?
  output          String?
  errorMessage    String?
  executionDetails Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attempt         Attempt          @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question        Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  testCaseResults TestCaseResult[]

  @@unique([attemptId, questionId])
  @@index([attemptId])
}

model TestCaseResult {
  id              String   @id @default(uuid())
  submissionId    String
  testCaseId      String
  passed          Boolean
  actualOutput    String?
  executionTimeMs Int?
  memoryMb        Float?
  timedOut        Boolean  @default(false)
  createdAt       DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  testCase   TestCase   @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@unique([submissionId, testCaseId])
  @@index([submissionId])
}

model Course {
  id          String   @id @default(uuid())
  tenantId    String
  title       String
  description String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments       Assignment[]
  chapters          CourseChapter[]
  courseAssignments  CourseAssignment[]
  scheduleEvents    BatchScheduleEvent[]
}

model Assignment {
  id          String    @id @default(uuid())
  courseId    String
  title       String
  description String?
  dueDate     DateTime?
  gradingType String    @default("auto") // auto, manual, hybrid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  assignmentTests AssignmentTest[]
}

model AssignmentTest {
  id           String @id @default(uuid())
  assignmentId String
  testId       String

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  test       Test       @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, testId])
}

// ----- LMS: Batch -----
model Batch {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members           BatchMember[]
  scheduleEvents    BatchScheduleEvent[]
  schedulerNotes    SchedulerNote[]
  batchVideos       BatchVideo[]
  courseAssignments  CourseAssignment[]
  batchTests        BatchTestAssignment[]

  @@index([tenantId])
}

model BatchTestAssignment {
  id         String   @id @default(uuid())
  batchId    String
  testId     String
  assignedAt DateTime @default(now())
  assignedBy String?

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  test  Test  @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([batchId, testId])
  @@index([batchId])
  @@index([testId])
}

model BatchMember {
  id       String   @id @default(uuid())
  batchId  String
  userId   String
  joinedAt DateTime @default(now())

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([batchId, userId])
  @@index([batchId])
  @@index([userId])
}

// ----- LMS: Course structure -----
model CourseChapter {
  id        String   @id @default(uuid())
  courseId   String
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  topics CourseTopic[]

  @@index([courseId])
}

model CourseTopic {
  id        String   @id @default(uuid())
  chapterId String
  title     String
  order     Int      @default(0)
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chapter     CourseChapter     @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  materials   CourseMaterial[]
  activities  CourseActivity[]
  evaluations CourseEvaluation[]

  @@index([chapterId])
}

model CourseMaterial {
  id         String   @id @default(uuid())
  topicId    String
  type       String   // pdf, link, video
  title      String
  storageKey String?
  url        String?
  mimeType   String?
  sizeBytes  Int?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  topic CourseTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

model CourseActivity {
  id        String   @id @default(uuid())
  topicId   String
  type      String   // assignment, discussion
  title     String
  config    Json     @default("{}")
  order     Int      @default(0)
  createdAt DateTime @default(now())

  topic       CourseTopic          @relation(fields: [topicId], references: [id], onDelete: Cascade)
  submissions ActivitySubmission[]

  @@index([topicId])
}

model CourseEvaluation {
  id        String   @id @default(uuid())
  topicId   String
  type      String   // quiz, test
  title     String
  testId    String?
  config    Json     @default("{}")
  order     Int      @default(0)
  createdAt DateTime @default(now())

  topic CourseTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  test  Test?       @relation(fields: [testId], references: [id], onDelete: SetNull)

  @@index([topicId])
  @@index([testId])
}

// ----- LMS: Assign course to Batch or User -----
model CourseAssignment {
  id         String    @id @default(uuid())
  tenantId   String
  courseId    String
  batchId    String?
  userId     String?
  assignedBy String
  assignedAt DateTime  @default(now())
  dueDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  batch  Batch? @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([courseId])
  @@index([batchId])
  @@index([userId])
}

// ----- LMS: Calendar per batch -----
model BatchScheduleEvent {
  id        String   @id @default(uuid())
  batchId   String
  title     String
  startAt   DateTime
  endAt     DateTime
  type      String?  // class, exam, live_session
  courseId   String?
  location  String?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batch  Batch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@index([startAt, endAt])
}

// ----- LMS: Notes on scheduler -----
model SchedulerNote {
  id        String   @id @default(uuid())
  batchId   String
  date      DateTime @db.Date
  content   String
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batch  Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@unique([batchId, date])
  @@index([batchId])
}

// ----- LMS: Batch videos -----
model BatchVideo {
  id              String   @id @default(uuid())
  batchId         String
  title           String
  description     String?
  storageKey      String
  mimeType        String   @default("video/mp4")
  sizeBytes       Int?
  durationSeconds Int?
  order           Int      @default(0)
  uploadedBy      String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  batch    Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  uploader User  @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)

  @@index([batchId])
}

// ----- Notifications -----
model Notification {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  type      String   // test_allocated, course_assigned, result_ready, announcement
  title     String
  message   String
  metadata  Json     @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([tenantId])
}

// ----- Activity Submissions -----
model ActivitySubmission {
  id            String   @id @default(uuid())
  activityId    String
  userId        String
  storageKey    String
  fileName      String
  fileSizeBytes Int?
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  activity CourseActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([activityId])
}

model RevisionLog {
  id        String   @id @default(uuid())
  tenantId  String
  module    String
  entityId  String
  action    String
  userId    String?
  userName  String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([tenantId, module, entityId])
  @@index([createdAt])
}

// ----- Business Enquiries (from landing page) -----
model Enquiry {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  category  String   // student | college | corporate | academic
  message   String   @db.Text
  status    String   @default("new") // new | contacted | closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

