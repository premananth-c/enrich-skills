DATABASE_URL="postgresql://user:password@localhost:5432/enrich_skills"
JWT_SECRET="your-secret-key-change-in-production"
PORT=3000

# Email (Resend — https://resend.com)
# Leave RESEND_API_KEY empty in development to log invite links to the console instead.
RESEND_API_KEY="re_your_resend_api_key_here"
# Must be a verified sender address or domain in your Resend account
EMAIL_FROM="noreply@yourdomain.com"
INVITE_BASE_URL="http://localhost:5173"

# Cloudflare R2 Storage
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="rankership"
# Optional: set this ONLY if you've configured public access on the bucket
# (e.g. a custom domain via Cloudflare or the pub-xxxx.r2.dev public URL).
# Leave empty to use short-lived presigned URLs for all file access (recommended for private buckets).
# e.g. https://assets.yourdomain.com  or  https://pub-xxxx.r2.dev
R2_PUBLIC_URL=""

# Allowed domains for video streaming and CORS (comma-separated hostnames, includes white-label tenant domains automatically)
ALLOWED_STREAMING_DOMAINS="rankership.com,www.rankership.com,student.rankership.com,admin.rankership.com,localhost"
