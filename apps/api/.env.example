DATABASE_URL="postgresql://user:password@localhost:5432/enrich_skills"
JWT_SECRET="your-secret-key-change-in-production"
PORT=3000

# ----- White-label control plane (M1+) -----
# Connection string for the Rankership control-plane DB. This DB holds
# tenant metadata (Tenant, TenantDomain, TenantDbConfig, TenantBranding,
# TenantPaymentCredential, SuperAdmin, Enquiry, AuditLog, ProvisionLog).
# Tenant business data lives in separate per-tenant DBs.
CONTROL_DATABASE_URL="postgresql://user:password@localhost:5432/enrich_control"

# Postgres superuser used ONLY by the tenant provisioning step
# (CREATE ROLE / CREATE DATABASE / GRANT). Never used at request time.
TENANT_DB_ADMIN_URL="postgresql://postgres:password@localhost:5432/postgres"

# Master key for encrypting per-tenant secrets at rest (DB connection
# strings, Razorpay/Stripe secrets, webhook secrets). Must be a
# base64-encoded 32-byte key. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TENANT_SECRETS_KEY=""

# Cloudflare for SaaS — used by the super-admin Domains tab to register
# per-tenant custom hostnames with automatic TLS. Leave CF_API_TOKEN empty
# to skip CF integration; domains will still be added locally and tenants
# can complete TLS manually.
CF_API_TOKEN=""
CF_ZONE_ID=""
# Hostname tenants point their custom domain CNAME at (e.g. lms.rankership.com).
CF_FALLBACK_ORIGIN=""

# Transition safety valve. When "1"/"true", requests that resolve no tenant use
# the legacy shared DB instead of returning 400 "Tenant context required". Set
# this during the white-label rollout so the new code behaves exactly like the
# old single-tenant app until the control plane is provisioned and every live
# host is a registered tenant. Unset it afterwards to enforce strict isolation.
WHITELABEL_LEGACY_FALLBACK=""

# Email (Resend — https://resend.com)
# Leave RESEND_API_KEY empty in development to log invite links to the console instead.
RESEND_API_KEY="re_your_resend_api_key_here"
# Must be a verified sender address or domain in your Resend account
EMAIL_FROM="noreply@yourdomain.com"
INVITE_BASE_URL="http://localhost:5173"

# Cloudflare R2 Storage
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="rankership"
# Optional: set this ONLY if you've configured public access on the bucket
# (e.g. a custom domain via Cloudflare or the pub-xxxx.r2.dev public URL).
# Leave empty to use short-lived presigned URLs for all file access (recommended for private buckets).
# e.g. https://assets.yourdomain.com  or  https://pub-xxxx.r2.dev
R2_PUBLIC_URL=""

# Allowed domains for video streaming and CORS (comma-separated hostnames, includes white-label tenant domains automatically)
ALLOWED_STREAMING_DOMAINS="rankership.com,www.rankership.com,student.rankership.com,admin.rankership.com,localhost"
